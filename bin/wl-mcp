#!/usr/bin/env bash
# wl-mcp — Workshop Lite MCP server entry point (host-neutral).
#
# Stable cross-host MCP entry point shim. Downstream host configs
# (codex `~/.codex/config.toml`, CC `~/.claude/mcp.json`, Antigravity TBD)
# point at this `bin/wl-mcp` path; internal implementation can reorganize
# without breaking multi-host configs.
#
# Install: symlink this into a PATH dir (e.g.
#   `ln -s "$PWD/bin/wl-mcp" ~/.local/bin/wl-mcp`), or prepend `bin/` to PATH.
#
# Requires: a workshop-lite checkout with
# `.claude/scripts/dev-mgmt/mcp_server.py` in the script's repo tree.
# The wrapper resolves the repo root from its own location so it works
# regardless of where it is invoked from.
#
# Pre-flight (cohort JJ Sub-fix 2 wl:2026-06-06-08 Amendment 1 algorithm):
#   1. Resolve <repo> from shim location (readlink -f → real path → ../).
#   2. Missing-venv handling FIRST (before any imports) — suggest
#      `python3 -m venv <venv> && pip install -r requirements-workshop-lite.txt`.
#   3. Pre-flight import-check using <venv>/bin/python3 EXPLICITLY
#      (never PATH `python3`) — closes system-Python contamination MED.
#   4. On import failure → SAME `pip install -r requirements-workshop-lite.txt`
#      suggestion for ALL consumer shapes (pyproject + non-pyproject alike).
#      No `pip install -e .` auto-suggestion — that path triggers the
#      partial-deps infinite-loop class (HIGH F1 devil-advocate 2026-06-06-04).
#   5. On preflight pass → `exec` mcp_server.py under the venv python.

set -euo pipefail

# Resolve the repo root from this script's location (follow symlinks).
SCRIPT="$(readlink -f "$0")"
REPO_ROOT="$(cd "$(dirname "$SCRIPT")/.." && pwd)"

MCP="$REPO_ROOT/.claude/scripts/dev-mgmt/mcp_server.py"
if [ ! -f "$MCP" ]; then
  echo "wl-mcp: mcp_server.py not found at $MCP" >&2
  exit 2
fi

REQ="$REPO_ROOT/.claude/scripts/dev-mgmt/requirements-workshop-lite.txt"
VENV="$REPO_ROOT/.venv"
VENV_PY="$VENV/bin/python3"

# Step 2: missing-venv check FIRST (before any imports). Never silently
# fall back to PATH python3 (that bypasses venv isolation entirely and
# is exactly the bug surfaced in wl:2026-06-06-08).
if [ ! -x "$VENV_PY" ]; then
  cat >&2 <<EOM
wl-mcp: virtual environment missing at $VENV.
Run: python3 -m venv "$VENV" && "$VENV/bin/pip" install -r "$REQ"
EOM
  exit 1
fi

# Step 3: pre-flight using venv python EXPLICITLY (closes MED system-
# Python contamination — devil-advocate 2026-06-06-04). 2>/dev/null
# suppresses Python's stderr so our own actionable message is the only
# diagnostic the user sees on failure.
if ! "$VENV_PY" -c "import mcp, yaml, pathspec" 2>/dev/null; then
  cat >&2 <<EOM
wl-mcp: workshop-lite runtime dependencies missing in $VENV.
Run: "$VENV/bin/pip" install -r "$REQ"
EOM
  exit 1
fi

# Step 5: all preflights pass — exec MCP server under venv python.
exec "$VENV_PY" "$MCP" "$@"
